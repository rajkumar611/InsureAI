apiVersion: v1
kind: Secret
metadata:
  name: insureai-secrets
  namespace: insureai
type: Opaque
stringData:
  POSTGRES_PASSWORD: "change-me-to-secure-password"
  ANTHROPIC_API_KEY: "sk-ant-your-real-api-key"
  DATABASE_URL: "postgresql+asyncpg://dbinsureai:change-me@postgres.insureai.svc.cluster.local:5432/aus_underwriting"
