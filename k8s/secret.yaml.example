# This file is a TEMPLATE. Do NOT commit actual values.
# Copy to k8s/secret.yaml, fill in real values, then apply.
# k8s/secret.yaml is in .gitignore and should never be committed.

apiVersion: v1
kind: Secret
metadata:
  name: insureai-secrets
  namespace: insureai
type: Opaque
stringData:
  # Replace with your actual Anthropic API key
  ANTHROPIC_API_KEY: "sk-ant-your-real-api-key-here"

  # Replace with a secure password (use openssl rand -base64 32)
  POSTGRES_PASSWORD: "your-secure-postgres-password-here"

  # Database URL (should reference POSTGRES_PASSWORD above)
  DATABASE_URL: "postgresql+asyncpg://dbinsureai:your-secure-postgres-password-here@postgres.insureai.svc.cluster.local:5432/aus_underwriting"
